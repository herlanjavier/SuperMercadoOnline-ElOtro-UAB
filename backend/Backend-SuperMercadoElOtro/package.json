{
  "name": "supermercado-online-el-otro-backend",
  "version": "1.0.0",
  "description": "Backend inicial para Supermercado Online El Otro",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand tests/integration",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand tests/unit"
  },
  "keywords": [
    "node",
    "express",
    "supabase",
    "supermercado"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18"
  }
}
